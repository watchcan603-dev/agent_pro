          }
        }
      ]
    },
    {
      "name": "phy",
      "description": "External PHY Registers (IEEE 802.3 Clause 22 MDIO) — physical layer status",
      "base_address": "MDIO",
      "registers": [
        {
          "name": "PHY_BMCR",
          "offset": "0x00",
          "address": "PHY_REG_0x00",
          "width": 16,
          "access": "RW",
          "description": "Basic Mode Control Register — PHY 基本控制",
          "fields": [
            {
              "name": "RESET",
              "bits": "15",
              "description": "PHY Reset. 1=reset, self-clears"
            },
            {
              "name": "LOOPBACK",
              "bits": "14",
              "description": "Loopback Mode"
            },
            {
              "name": "SPEED_LSB",
              "bits": "13",
              "description": "Speed Select (LSB)"
            },
            {
              "name": "AN_ENABLE",
              "bits": "12",
              "description": "Auto-Negotiation Enable. 1=enabled"
            },
            {
              "name": "POWER_DOWN",
              "bits": "11",
              "description": "Power Down. 1=power down mode"
            },
            {
              "name": "ISOLATE",
              "bits": "10",
              "description": "Isolate. 1=electrically isolated from MII"
            },
            {
              "name": "RESTART_AN",
              "bits": "9",
              "description": "Restart Auto-Negotiation"
            },
            {
              "name": "DUPLEX",
              "bits": "8",
              "description": "Duplex Mode. 0=half, 1=full"
            },
            {
              "name": "COLLISION_TEST",
              "bits": "7",
              "description": "Collision Test"
            },
            {
              "name": "SPEED_MSB",
              "bits": "6",
              "description": "Speed Select (MSB)"
            }
          ],
          "error_values": {
            "POWER_DOWN=1": "PHY 处于省电模式 — 链路必然 DOWN",
            "ISOLATE=1": "PHY 电气隔离 — MII 接口断开",
            "AN_ENABLE=0": "自协商关闭 — 可能需要手动配置速率双工"
          }
        },
        {
          "name": "PHY_BMSR",
          "offset": "0x01",
          "address": "PHY_REG_0x01",
          "width": 16,
          "access": "RO",
          "description": "Basic Mode Status Register — PHY 状态和能力",
          "fields": [
            {
              "name": "AN_COMPLETE",
              "bits": "5",
              "description": "Auto-Negotiation Complete"
            },
            {
              "name": "REMOTE_FAULT",
              "bits": "4",
              "description": "Remote Fault detected"
            },
            {
              "name": "AN_ABLE",
              "bits": "3",
              "description": "Auto-Negotiation Ability"
